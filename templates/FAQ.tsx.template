/**
 * FAQ.tsx — 공통 FAQ 컴포넌트 (microsaas-infra 표준)
 *
 * 사용처: 각 사이트의 `src/components/FAQ.tsx` 로 복붙해서 사용한다.
 * (CDK 레포 import 가 아니라 i18n-reusable-template 와 동일한 "복붙 후 사이트별 미세조정" 방식.)
 *
 * 책임:
 * 1. FAQ 항목 리스트(<dl> 의미론) 렌더링.
 * 2. schema.org `FAQPage` JSON-LD 객체를 만들어 `onJsonLd` 콜백으로 부모(SEO)에 전달
 *    하거나, `<script type="application/ld+json">` 을 직접 인라인 출력.
 *
 * 통합 패턴 (권장):
 *   - 페이지 컴포넌트(예: pages/Faq.tsx)에서 `buildFaqJsonLd(faqs)` 헬퍼만 호출해
 *     기존 `SEO` 컴포넌트의 `jsonLd={[webApp, howTo, faqJsonLd]}` 배열에 합쳐 넣는다.
 *   - JSON-LD 는 SEO 가 한 번에 출력하므로 `<FAQ>` 컴포넌트 자체는 마크업만 책임.
 *   - 이렇게 하면 `<head>` 의 `<script type="application/ld+json">` 개수가 늘어나지 않는다.
 *
 * Props:
 *   - `faqs`: { q: string; a: string }[] (5~8개 권장, 최소 5개)
 *   - `inlineJsonLd?`: boolean (기본 false). true 면 컴포넌트가 JSON-LD 도 직접 인라인 출력.
 *   - `headingLevel?`: 'h2' | 'h3' (기본 'h2')
 *   - `idPrefix?`: string (앵커 링크용, 기본 'faq')
 */

import React from 'react';

export interface FAQItem {
  q: string;
  a: string;
}

export interface FAQProps {
  faqs: FAQItem[];
  inlineJsonLd?: boolean;
  headingLevel?: 'h2' | 'h3';
  idPrefix?: string;
}

/**
 * FAQPage JSON-LD 객체를 만든다. SEO 컴포넌트의 jsonLd 배열에 그대로 push 한다.
 * 5개 미만이면 검색엔진이 FAQ 리치 결과로 인식하지 않을 가능성이 높으므로 빈 객체 반환.
 */
export function buildFaqJsonLd(faqs: FAQItem[]): object | null {
  if (!faqs || faqs.length < 5) return null;
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map(({ q, a }) => ({
      '@type': 'Question',
      name: q,
      acceptedAnswer: {
        '@type': 'Answer',
        text: a,
      },
    })),
  };
}

/** Slug 화: 한글·영문·숫자만 남기고 나머지는 하이픈. 같은 페이지 내 중복은 부모가 책임. */
function toSlug(s: string, idx: number): string {
  const base = s
    .normalize('NFKD')
    .replace(/[^\p{L}\p{N}\s-]/gu, '')
    .trim()
    .replace(/\s+/g, '-')
    .toLowerCase()
    .slice(0, 60);
  return base || `q-${idx}`;
}

const FAQ: React.FC<FAQProps> = ({
  faqs,
  inlineJsonLd = false,
  headingLevel = 'h2',
  idPrefix = 'faq',
}) => {
  if (!faqs || faqs.length === 0) return null;

  const Heading = headingLevel;
  const jsonLd = inlineJsonLd ? buildFaqJsonLd(faqs) : null;

  return (
    <section aria-labelledby={`${idPrefix}-title`} className="space-y-4">
      <Heading id={`${idPrefix}-title`} className="text-base font-semibold text-slate-900">
        자주 묻는 질문 / FAQ
      </Heading>

      <dl className="space-y-3">
        {faqs.map((item, idx) => {
          const id = `${idPrefix}-${toSlug(item.q, idx)}`;
          return (
            <div
              key={id}
              id={id}
              className="rounded-lg border border-slate-200 bg-white p-4 shadow-sm"
            >
              <dt className="text-sm font-semibold text-slate-900">
                <a href={`#${id}`} className="hover:underline">
                  Q. {item.q}
                </a>
              </dt>
              <dd className="mt-2 whitespace-pre-line text-[13px] leading-relaxed text-slate-700">
                A. {item.a}
              </dd>
            </div>
          );
        })}
      </dl>

      {jsonLd && (
        <script
          type="application/ld+json"
          dangerouslySetInnerHTML={{ __html: JSON.stringify(jsonLd) }}
        />
      )}
    </section>
  );
};

export default FAQ;

